# SpeedFlow Platform Environment Variables

# LLM Provider (optional - agents work in rule-based fallback mode without keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_TOPIC=raw_stream
KAFKA_PROCESSED_TOPIC=processed_stream
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Redis (AI bridges & scraper job queue)
REDIS_URL=redis://redis:6379/0

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpassword
POSTGRES_DB=platform_db

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Service URLs
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8000
SCRAPER_BRIDGE_QUEUE=scraper:jobs
PROCESSING_BRIDGE_QUEUE=processing:jobs
CONFIG_BRIDGE_QUEUE=config:jobs

# FinOps budgets (USD/day)
DAILY_SCRAPING_BUDGET=500
DAILY_COMPUTE_BUDGET=300
DAILY_LLM_BUDGET=100

# Crawlee (Apify) — scalable crawling with proxy rotation
CRAWLEE_PROXY_URL=
CRAWLEE_QUEUE=crawlee:jobs
CRAWLEE_WORKER_REPLICAS=3

# Avro serialization via Schema Registry
USE_AVRO=true

# Platform API
PLATFORM_API_URL=http://localhost:8020

# GitOps (Config Agent output)
GITOPS_REPO_PATH=/gitops
GITOPS_BRANCH=main
GITOPS_DRY_RUN=true
